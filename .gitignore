# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── 大文件：图片索引 (194MB，超 GitHub 100MB 限制) ──
knowledge_base/image_index.json

# ── 大文件：2604 张原始插图 (140MB) ──
手册/插图/

