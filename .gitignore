server_err.txt
server_out.txt
_fix*.py
_airfryer_debug.json

# ── 评估输出（可重跑） ──
submission*.csv
!submission_example.csv
submission*_detail.json

# ── 系统文件 ──
desktop.ini
# ── 数据文件（竞赛数据，不公开） ──
data/

